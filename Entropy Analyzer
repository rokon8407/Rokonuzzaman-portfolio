import React, { useState } from 'react';
import { Card, CardHeader, CardTitle, CardContent } from '@/components/ui/card';
import { Button } from '@/components/ui/button';
import { RadioGroup, RadioGroupItem } from '@/components/ui/radio-group';
import { Label } from '@/components/ui/label';
import { Textarea } from '@/components/ui/textarea';

const EntropyAnalyzer = () => {
  const [mainContent, setMainContent] = useState('');
  const [mode, setMode] = useState('entire');
  const [competitors, setCompetitors] = useState([{ id: 1, content: '' }]);
  const [results, setResults] = useState(null);

  // Calculate entropy of a string
  const calculateEntropy = (str) => {
    if (!str) return 0;
    const len = str.length;
    const frequencies = {};
    
    // Count character frequencies
    for (let i = 0; i < len; i++) {
      frequencies[str[i]] = (frequencies[str[i]] || 0) + 1;
    }
    
    // Calculate entropy
    return Object.values(frequencies).reduce((entropy, freq) => {
      const probability = freq / len;
      return entropy - probability * Math.log2(probability);
    }, 0);
  };

  // Calculate entropy based on selected mode
  const calculateModeEntropy = (text) => {
    switch (mode) {
      case 'line':
        return text.split('\n').map(calculateEntropy);
      case 'paragraph':
        return text.split('\n\n').map(calculateEntropy);
      default:
        return calculateEntropy(text);
    }
  };

  // Handle analysis
  const analyzeContent = () => {
    const mainResults = calculateModeEntropy(mainContent);
    const competitorResults = competitors.map(comp => ({
      id: comp.id,
      entropy: calculateModeEntropy(comp.content)
    }));

    setResults({
      main: mainResults,
      competitors: competitorResults
    });
  };

  // Add new competitor
  const addCompetitor = () => {
    if (competitors.length < 3) {
      setCompetitors([...competitors, { 
        id: competitors.length + 1, 
        content: '' 
      }]);
    }
  };

  // Update competitor content
  const updateCompetitor = (id, content) => {
    setCompetitors(competitors.map(comp => 
      comp.id === id ? { ...comp, content } : comp
    ));
  };

  const formatEntropyResult = (entropy) => {
    if (Array.isArray(entropy)) {
      return entropy.map((e, i) => (
        <div key={i} className="mb-1">
          {mode === 'line' ? 'Line' : 'Paragraph'} {i + 1}: {e.toFixed(2)}
        </div>
      ));
    }
    return entropy.toFixed(2);
  };

  return (
    <Card className="w-full max-w-3xl mx-auto">
      <CardHeader>
        <CardTitle className="text-center">Advanced Entropy Analyzer</CardTitle>
      </CardHeader>
      <CardContent className="space-y-6">
        {/* Main Content Input */}
        <div>
          <Label>Enter your content here:</Label>
          <Textarea 
            value={mainContent}
            onChange={(e) => setMainContent(e.target.value)}
            className="min-h-32"
          />
        </div>

        {/* Mode Selection */}
        <div>
          <Label>Entropy Calculation Mode:</Label>
          <RadioGroup 
            value={mode}
            onValueChange={setMode}
            className="flex flex-col space-y-2 mt-2"
          >
            <div className="flex items-center space-x-2">
              <RadioGroupItem value="entire" id="entire" />
              <Label htmlFor="entire">Entire Text</Label>
            </div>
            <div className="flex items-center space-x-2">
              <RadioGroupItem value="line" id="line" />
              <Label htmlFor="line">Each Line</Label>
            </div>
            <div className="flex items-center space-x-2">
              <RadioGroupItem value="paragraph" id="paragraph" />
              <Label htmlFor="paragraph">Each Paragraph</Label>
            </div>
          </RadioGroup>
        </div>

        {/* Competitor Inputs */}
        <div className="space-y-4">
          <Label>Competitor Content (Optional):</Label>
          {competitors.map((comp) => (
            <Textarea
              key={comp.id}
              value={comp.content}
              onChange={(e) => updateCompetitor(comp.id, e.target.value)}
              placeholder={`Competitor ${comp.id} content...`}
              className="min-h-24"
            />
          ))}
          {competitors.length < 3 && (
            <Button 
              onClick={addCompetitor}
              variant="outline"
              className="w-full"
            >
              Add Competitor
            </Button>
          )}
        </div>

        {/* Analyze Button */}
        <Button 
          onClick={analyzeContent}
          className="w-full"
        >
          Analyze Content
        </Button>

        {/* Results Display */}
        {results && (
          <div className="mt-6 p-4 border rounded-lg">
            <h3 className="font-semibold mb-4">Results:</h3>
            <div className="space-y-4">
              <div>
                <strong>Main Content Entropy:</strong>
                <div className="ml-4">
                  {formatEntropyResult(results.main)}
                </div>
              </div>
              {results.competitors.map((comp) => (
                <div key={comp.id}>
                  <strong>Competitor {comp.id} Entropy:</strong>
                  <div className="ml-4">
                    {formatEntropyResult(comp.entropy)}
                  </div>
                </div>
              ))}
            </div>
          </div>
        )}
      </CardContent>
    </Card>
  );
};

export default EntropyAnalyzer;
